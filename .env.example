# Server
PORT=8080
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Auth0
AUTH0_DOMAIN=squadpitch.us.auth0.com
AUTH0_AUDIENCE=https://api.squadpitch.com

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/squadpitch

# Redis
REDIS_URL=redis://localhost:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Fal.ai
FAL_API_KEY=
FAL_DEFAULT_MODEL=fal-ai/flux/dev

# OAuth token encryption (base64-encoded 32 bytes)
TOKEN_ENCRYPTION_KEY=

# OAuth state signing (random 32+ bytes)
OAUTH_STATE_SECRET=

# Meta / Instagram / Facebook
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# Workers
ENABLE_WORKERS=true
