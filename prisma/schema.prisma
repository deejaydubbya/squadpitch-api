generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  EDITOR
  VIEWER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum Channel {
  INSTAGRAM
  TIKTOK
  X
  LINKEDIN
  FACEBOOK
  YOUTUBE
}

enum MediaMode {
  BRAND_ASSETS_ONLY
  BRAND_ASSETS_PLUS_AI
  AI_CHARACTER
}

enum DraftKind {
  POST
  CAPTION
  VIDEO_SCRIPT
  CAROUSEL
  HOOKS
  CTA_VARIANTS
  REPLY
}

enum DraftStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
  FAILED
}

enum ConnectionStatus {
  CONNECTED
  NEEDS_RECONNECT
  EXPIRED
  REVOKED
  ERROR
}

enum MediaAssetSource {
  UPLOAD
  AI_GENERATED
  IMPORTED
}

enum MediaAssetStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum DataSourceType {
  MANUAL
  URL
  CSV
  TEXT
  GOOGLE_SHEETS
  NOTION
}

enum DataItemStatus {
  ACTIVE
  ARCHIVED
}

enum DataItemType {
  TESTIMONIAL
  CASE_STUDY
  PRODUCT_LAUNCH
  PROMOTION
  STATISTIC
  MILESTONE
  FAQ
  TEAM_SPOTLIGHT
  INDUSTRY_NEWS
  EVENT
  CUSTOM
}

enum BlueprintCategory {
  SOCIAL_PROOF
  EDUCATION
  BEHIND_THE_SCENES
  PROMOTION
  ENGAGEMENT
  STORYTELLING
  AUTHORITY
  SEASONAL
}

// ── User ───────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  auth0Sub  String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Client ─────────────────────────────────────────────────────────────

model Client {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      ClientStatus @default(ACTIVE)
  logoUrl     String?
  industryKey String?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  brandProfile      BrandProfile?
  voiceProfile      VoiceProfile?
  mediaProfile      MediaProfile?
  channelSettings   ChannelSettings[]
  drafts            Draft[]
  moderationLogs    ModerationLog[]
  connections       ChannelConnection[]
  mediaAssets       MediaAsset[]
  postMetrics       PostMetrics[]
  rawMetrics        RawMetric[]
  normalizedMetrics NormalizedMetric[]
  postInsights      PostInsight[]
  workspaceAnalytics WorkspaceAnalytics?
  analyticsSnapshots AnalyticsSnapshot[]
  dataSources        WorkspaceDataSource[]
  dataItems          WorkspaceDataItem[]

  @@index([status])
  @@map("clients")
}

// ── Profiles ───────────────────────────────────────────────────────────

model BrandProfile {
  clientId     String   @id
  description  String?  @db.Text
  industry     String?
  audience     String?  @db.Text
  website      String?
  socialsJson  Json?
  offers       String?  @db.Text
  competitors  String?  @db.Text
  examplePosts Json?
  updatedBy    String?
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model VoiceProfile {
  clientId       String   @id
  tone           String?
  voiceRulesJson Json
  bannedPhrases  String[]
  ctaPreferences Json?
  contentBuckets Json
  version        Int      @default(1)
  updatedBy      String?
  updatedAt      DateTime @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("voice_profiles")
}

model MediaProfile {
  clientId           String    @id
  mode               MediaMode @default(BRAND_ASSETS_ONLY)
  visualStyle        String?   @db.Text
  assetLibraryJson   Json?
  characterPrompt    String?   @db.Text
  basePromptTemplate String?   @db.Text
  loraModelUrl       String?
  loraTriggerWord    String?
  loraScale          Float?    @default(1.0)
  updatedBy          String?
  updatedAt          DateTime  @updatedAt
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("media_profiles")
}

// ── Channel Settings ───────────────────────────────────────────────────

model ChannelSettings {
  id               String   @id @default(cuid())
  clientId         String
  channel          Channel
  isEnabled        Boolean  @default(true)
  maxChars         Int?
  allowEmoji       Boolean  @default(true)
  trailingHashtags String[]
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, channel])
  @@map("channel_settings")
}

// ── Draft ──────────────────────────────────────────────────────────────

model Draft {
  id                   String      @id @default(cuid())
  clientId             String
  kind                 DraftKind
  status               DraftStatus @default(DRAFT)
  channel              Channel
  bucketKey            String?

  generationGuidance   String      @db.Text
  modelUsed            String?
  promptVersion        Int         @default(1)

  body                 String      @db.Text
  hooks                String[]
  hashtags             String[]
  cta                  String?
  variations           Json?
  altText              String?     @db.Text
  imageGuidance        String?     @db.Text
  warnings             String[]

  mediaUrl             String?
  mediaType            String?
  externalPostId       String?
  externalPostUrl      String?
  publishError         String?     @db.Text
  publishAttempts      Int         @default(0)
  lastPublishAttemptAt DateTime?
  idempotencyKey       String?     @unique
  publishSource        String?

  createdBy            String
  approvedBy           String?
  approvedAt           DateTime?
  rejectedReason       String?
  scheduledFor         DateTime?
  publishedAt          DateTime?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  client               Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  moderationLogs       ModerationLog[]
  mediaAssets          MediaAsset[]
  draftAssets          DraftAsset[]
  metrics              PostMetrics?
  rawMetric            RawMetric[]
  normalizedMetric     NormalizedMetric?
  postInsight          PostInsight?
  contentSources       GeneratedContentSource[]

  @@index([clientId, status])
  @@index([clientId, channel])
  @@index([status, scheduledFor])
  @@map("drafts")
}

// ── Channel Connection ─────────────────────────────────────────────────

model ChannelConnection {
  id                String           @id @default(cuid())
  clientId          String
  channel           Channel
  externalAccountId String?
  displayName       String?
  accessToken       String           @db.Text
  refreshToken      String?          @db.Text
  tokenExpiresAt    DateTime?
  scopes            String[]
  status            ConnectionStatus @default(CONNECTED)
  lastValidatedAt   DateTime?
  lastError         String?          @db.Text
  lastRefreshAt     DateTime?
  refreshFailedAt   DateTime?
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, channel])
  @@index([channel, status])
  @@map("channel_connections")
}

// ── Moderation Log ─────────────────────────────────────────────────────

model ModerationLog {
  id         String      @id @default(cuid())
  draftId    String
  clientId   String
  fromStatus DraftStatus
  toStatus   DraftStatus
  actorSub   String
  reason     String?
  createdAt  DateTime    @default(now())
  draft      Draft       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@map("moderation_logs")
}

// ── Media Asset ────────────────────────────────────────────────────────

model MediaAsset {
  id                String           @id @default(cuid())
  clientId          String
  source            MediaAssetSource
  status            MediaAssetStatus @default(READY)
  progressStage     String?

  url               String?
  publicId          String?
  width             Int?
  height            Int?
  bytes             Int?
  mimeType          String?
  assetType         String           @default("image")
  thumbnailUrl      String?
  videoDurationSec  Int?

  filename          String?
  altText           String?          @db.Text
  caption           String?

  draftId           String?
  draft             Draft?           @relation(fields: [draftId], references: [id], onDelete: SetNull)
  displayOrder      Int              @default(0)

  falModelId        String?
  renderedPrompt    String?          @db.Text
  negativePrompt    String?          @db.Text
  loraSnapshot      String?
  loraScaleSnapshot Float?
  seed              BigInt?
  externalJobId     String?
  durationMs        Int?
  errorMessage      String?          @db.Text

  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  draftAssets       DraftAsset[]

  @@index([clientId, status])
  @@index([clientId, source])
  @@index([draftId])
  @@map("media_assets")
}

// ── Draft-Asset Join Table ────────────────────────────────────────────

model DraftAsset {
  id         String   @id @default(cuid())
  draftId    String
  assetId    String
  role       String?  // "primary", "thumbnail", or null
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  draft      Draft      @relation(fields: [draftId], references: [id], onDelete: Cascade)
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([draftId, assetId])
  @@index([assetId])
  @@map("draft_assets")
}

// ── Subscription ──────────────────────────────────────────────────────

enum PlanTier {
  STARTER
  GROWTH
  PRO
  AGENCY
}

enum AiActionType {
  GENERATE_POST
  REGENERATE
  PARSE
  IMAGE
  VIDEO
  IDEAS
  ONBOARDING
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  tier                 PlanTier           @default(STARTER)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("subscriptions")
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  posts       Int      @default(0)
  images      Int      @default(0)
  videos      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, periodStart])
  @@map("usage_records")
}

model AiUsageLog {
  id                 String       @id @default(cuid())
  userId             String
  clientId           String?
  actionType         AiActionType
  model              String
  promptTokens       Int          @default(0)
  completionTokens   Int          @default(0)
  estimatedCostCents Float        @default(0)
  metadata           Json?
  createdAt          DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@map("ai_usage_logs")
}

// ── Post Metrics ───────────────────────────────────────────────────────

model PostMetrics {
  id             String   @id @default(cuid())
  draftId        String   @unique
  clientId       String
  channel        Channel

  impressions    Int      @default(0)
  reach          Int      @default(0)
  engagement     Int      @default(0)
  clicks         Int      @default(0)
  saves          Int      @default(0)
  shares         Int      @default(0)
  comments       Int      @default(0)
  likes          Int      @default(0)
  engagementRate Float?

  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  draft          Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, channel])
  @@index([clientId, lastSyncedAt])
  @@map("post_metrics")
}

// ── Notifications ────────────────────────────────────────────────────

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  pushEnabled     Boolean  @default(false)
  digestEnabled   Boolean  @default(true)
  phoneNumber     String?
  preferencesJson Json     @default("{\"POST_PUBLISHED\":true,\"POST_FAILED\":true,\"USAGE_LIMIT_NEARING\":true,\"CONNECTION_EXPIRED\":true,\"BATCH_COMPLETE\":true}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationLog {
  id                String   @id @default(cuid())
  userId            String
  eventType         String
  channel           String   // "email" | "sms"
  status            String   @default("queued") // queued | sent | failed | skipped
  provider          String?  // "postmark" | "twilio"
  providerMessageId String?
  resourceType      String?  // "draft" | "connection" | "usage" etc.
  resourceId        String?
  errorMessage      String?  @db.Text
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, eventType])
  @@index([userId, eventType, resourceId])
  @@map("notification_logs")
}

// ── In-App Notifications ────────────────────────────────────────────

model Notification {
  id           String   @id @default(cuid())
  userId       String
  eventType    String
  title        String
  message      String   @db.Text
  linkUrl      String?
  resourceType String?
  resourceId   String?
  read         Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ActivityEvent {
  id           String   @id @default(cuid())
  userId       String
  clientId     String?
  eventType    String
  title        String
  description  String?  @db.Text
  icon         String?
  linkUrl      String?
  resourceType String?
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, clientId, createdAt])
  @@map("activity_events")
}

// ── Slack Integration ─────────────────────────────────────────────────

model SlackConnection {
  id               String   @id @default(cuid())
  userId           String   @unique
  webhookUrl       String   @db.Text
  channelName      String?
  isActive         Boolean  @default(true)
  subscribedEvents Json     @default("[\"POST_FAILED\",\"POST_PUBLISHED\",\"BATCH_COMPLETE\",\"CONNECTION_EXPIRED\"]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("slack_connections")
}

// ── Outbound Webhooks ─────────────────────────────────────────────────

model OutboundWebhook {
  id               String   @id @default(cuid())
  userId           String
  targetUrl        String   @db.Text
  secret           String
  subscribedEvents Json     @default("[\"POST_PUBLISHED\",\"POST_FAILED\",\"BATCH_COMPLETE\",\"CONNECTION_EXPIRED\"]")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  deliveryLogs     WebhookDeliveryLog[]

  @@index([userId])
  @@map("outbound_webhooks")
}

model WebhookDeliveryLog {
  id             String   @id @default(cuid())
  webhookId      String
  eventType      String
  requestBody    Json
  responseStatus Int?
  responseBody   String?  @db.Text
  status         String   @default("pending") // pending | success | failed
  attemptCount   Int      @default(0)
  createdAt      DateTime @default(now())

  webhook        OutboundWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@map("webhook_delivery_logs")
}

// ── Generic Integrations ────────────────────────────────────────────

model Integration {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "slack" | "webhook" | "notion" | "google_sheets"
  name      String
  config    Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs IntegrationLog[]

  @@index([userId, type])
  @@map("integrations")
}

model IntegrationLog {
  id            String   @id @default(cuid())
  integrationId String
  eventType     String
  status        String   @default("pending") // "pending" | "success" | "failed"
  responseData  Json?
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@map("integration_logs")
}

// ── Analytics ─────────────────────────────────────────────────────────

model RawMetric {
  id             String   @id @default(cuid())
  clientId       String
  draftId        String
  channel        Channel
  externalPostId String?
  dataJson       Json
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  draft          Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([draftId])
  @@map("raw_metrics")
}

model NormalizedMetric {
  id                     String   @id @default(cuid())
  clientId               String
  draftId                String   @unique
  channel                Channel
  impressions            Int?
  reach                  Int?
  engagements            Int?
  clicks                 Int?
  engagementRate         Float?
  relativeEngagementRate Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  draft                  Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([clientId, channel])
  @@map("normalized_metrics")
}

model PostInsight {
  id                 String   @id @default(cuid())
  clientId           String
  draftId            String   @unique
  performanceScore   Float?
  contentType        String?
  hookType           String?
  sentiment          String?
  lengthBucket       String?
  mediaType          String?
  postingTimeBucket  String?
  recommendationTags Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  draft              Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("post_insights")
}

// ── Workspace Analytics ──────────────────────────────────────────────

model WorkspaceAnalytics {
  id                  String   @id @default(cuid())
  clientId            String   @unique
  avgEngagementRate   Float?
  avgPerformanceScore Float?
  totalPosts          Int      @default(0)
  totalPublishedPosts Int      @default(0)
  totalReach          Int      @default(0)
  totalEngagements    Int      @default(0)
  topPlatform         String?
  bestContentType     String?
  bestMediaType       String?
  lastCalculatedAt    DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("workspace_analytics")
}

model AnalyticsSnapshot {
  id                  String   @id @default(cuid())
  clientId            String
  snapshotDate        DateTime @db.Date
  avgPerformanceScore Float?
  avgEngagementRate   Float?
  totalPosts          Int      @default(0)
  totalReach          Int      @default(0)
  totalEngagements    Int      @default(0)
  createdAt           DateTime @default(now())
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, snapshotDate])
  @@index([clientId, snapshotDate])
  @@map("analytics_snapshots")
}

// ── Business Data ────────────────────────────────────────────────────

model WorkspaceDataSource {
  id        String         @id @default(cuid())
  clientId  String
  type      DataSourceType @default(MANUAL)
  name      String
  config    Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dataItems WorkspaceDataItem[]

  @@index([clientId])
  @@map("workspace_data_sources")
}

model WorkspaceDataItem {
  id           String         @id @default(cuid())
  clientId     String
  dataSourceId String
  type         DataItemType
  status       DataItemStatus @default(ACTIVE)
  title        String
  summary      String?        @db.Text
  dataJson     Json
  tags         String[]
  priority     Int            @default(0)
  expiresAt    DateTime?
  usageCount   Int            @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  client         Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dataSource     WorkspaceDataSource      @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  contentSources GeneratedContentSource[]
  performance    DataItemPerformance?

  @@index([clientId, status])
  @@index([clientId, type])
  @@map("workspace_data_items")
}

model ContentBlueprint {
  id                String            @id @default(cuid())
  slug              String            @unique
  name              String
  description       String            @db.Text
  category          BlueprintCategory
  promptTemplate    String            @db.Text
  applicableTypes   DataItemType[]
  applicableChannels Channel[]
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  contentSources GeneratedContentSource[]
  performance    BlueprintPerformance?

  @@index([category])
  @@map("content_blueprints")
}

model GeneratedContentSource {
  id          String   @id @default(cuid())
  draftId     String
  dataItemId  String
  blueprintId String
  createdAt   DateTime @default(now())

  draft     Draft             @relation(fields: [draftId], references: [id], onDelete: Cascade)
  dataItem  WorkspaceDataItem @relation(fields: [dataItemId], references: [id], onDelete: Cascade)
  blueprint ContentBlueprint  @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([dataItemId])
  @@index([blueprintId])
  @@map("generated_content_sources")
}

model DataItemPerformance {
  id             String   @id @default(cuid())
  dataItemId     String   @unique
  totalDrafts    Int      @default(0)
  totalPublished Int      @default(0)
  avgEngagement        Float?
  avgPerformanceScore  Float?
  lastCalculated DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dataItem WorkspaceDataItem @relation(fields: [dataItemId], references: [id], onDelete: Cascade)

  @@map("data_item_performance")
}

model BlueprintPerformance {
  id             String   @id @default(cuid())
  blueprintId    String   @unique
  totalDrafts    Int      @default(0)
  totalPublished Int      @default(0)
  avgEngagement        Float?
  avgPerformanceScore  Float?
  lastCalculated DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blueprint ContentBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@map("blueprint_performance")
}
